<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════════════════
         Colors.xaml — THE SINGLE SOURCE OF COLOR TRUTH
         Sci-fi dark aesthetic: deep space black + amber/orange fire + cyan-white data
         ══════════════════════════════════════════════════════════ -->

    <!-- ══ Deep Backgrounds ══ -->
    <Color x:Key="BgPrimary">#FF070B12</Color>
    <Color x:Key="BgSecondary">#FF0F1620</Color>
    <Color x:Key="BgTertiary">#FF16202E</Color>

    <!-- ══ Surfaces ══ -->
    <Color x:Key="BgSurface">#FF1C2A3A</Color>
    <Color x:Key="BgSurfaceHover">#FF223244</Color>
    <Color x:Key="BgSurfacePressed">#FF293D52</Color>

    <!-- ══ Orange/Amber — Brand Accent (splash, mode cards, highlights) ══ -->
    <Color x:Key="AccentOrange">#FFFF6D1F</Color>
    <Color x:Key="AccentOrangeGlow">#FFFF4500</Color>
    <Color x:Key="AccentAmber">#FFFFB300</Color>
    <Color x:Key="AccentGold">#FFFFC947</Color>

    <!-- ══ Cyan — Interactive Accent (data readouts, selections) ══ -->
    <Color x:Key="AccentCyan">#FF00D4FF</Color>
    <Color x:Key="AccentCyanDim">#FF007EA8</Color>

    <!-- ══ Text ══ -->
    <Color x:Key="TextPrimary">#FFE8ECF4</Color>
    <Color x:Key="TextSecondary">#FF7A8BA8</Color>
    <Color x:Key="TextDisabled">#FF344258</Color>
    <Color x:Key="TextAccent">#FFFF6D1F</Color>
    <Color x:Key="TextData">#FF00D4FF</Color>
    <Color x:Key="TextError">#FFFF4444</Color>

    <!-- ══ Borders ══ -->
    <Color x:Key="BorderSubtle">#FF131E2C</Color>
    <Color x:Key="BorderBase">#FF1E2E42</Color>
    <Color x:Key="BorderStrong">#FF2A3F5C</Color>
    <Color x:Key="BorderAccent">#FFFF6D1F</Color>
    <Color x:Key="BorderError">#FFFF4444</Color>

    <!-- ══ Status ══ -->
    <Color x:Key="StatusGreen">#FF22C55E</Color>
    <Color x:Key="StatusYellow">#FFFFB300</Color>
    <Color x:Key="StatusRed">#FFFF4444</Color>

    <!-- ══ Modal / Overlay ══ -->
    <Color x:Key="ModalScrim">#CC000000</Color>

    <!-- ══════════════════════════════════════════════════════════
         BRUSHES — Derived from canonical color tokens above.
         All UI controls reference these brush keys.
         ══════════════════════════════════════════════════════════ -->

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="BgPrimaryBrush"       Color="{StaticResource BgPrimary}"/>
    <SolidColorBrush x:Key="BgSecondaryBrush"      Color="{StaticResource BgSecondary}"/>
    <SolidColorBrush x:Key="BgTertiaryBrush"       Color="{StaticResource BgTertiary}"/>

    <!-- Surfaces -->
    <SolidColorBrush x:Key="BgSurfaceBrush"        Color="{StaticResource BgSurface}"/>
    <SolidColorBrush x:Key="BgSurfaceHoverBrush"   Color="{StaticResource BgSurfaceHover}"/>
    <SolidColorBrush x:Key="BgSurfacePressedBrush" Color="{StaticResource BgSurfacePressed}"/>

    <!-- Orange/Amber Brand -->
    <SolidColorBrush x:Key="AccentOrangeBrush"     Color="{StaticResource AccentOrange}"/>
    <SolidColorBrush x:Key="AccentOrangeGlowBrush" Color="{StaticResource AccentOrangeGlow}"/>
    <SolidColorBrush x:Key="AccentAmberBrush"      Color="{StaticResource AccentAmber}"/>
    <SolidColorBrush x:Key="AccentGoldBrush"       Color="{StaticResource AccentGold}"/>

    <!-- Cyan Interactive -->
    <SolidColorBrush x:Key="AccentCyanBrush"       Color="{StaticResource AccentCyan}"/>
    <SolidColorBrush x:Key="AccentCyanDimBrush"    Color="{StaticResource AccentCyanDim}"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush"      Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"     Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextDisabledBrush"      Color="{StaticResource TextDisabled}"/>
    <SolidColorBrush x:Key="TextAccentBrush"        Color="{StaticResource TextAccent}"/>
    <SolidColorBrush x:Key="TextDataBrush"          Color="{StaticResource TextData}"/>
    <SolidColorBrush x:Key="TextErrorBrush"         Color="{StaticResource TextError}"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderSubtleBrush"     Color="{StaticResource BorderSubtle}"/>
    <SolidColorBrush x:Key="BorderBaseBrush"        Color="{StaticResource BorderBase}"/>
    <SolidColorBrush x:Key="BorderStrongBrush"      Color="{StaticResource BorderStrong}"/>
    <SolidColorBrush x:Key="BorderAccentBrush"      Color="{StaticResource BorderAccent}"/>
    <SolidColorBrush x:Key="BorderErrorBrush"       Color="{StaticResource BorderError}"/>

    <!-- Status -->
    <SolidColorBrush x:Key="StatusGreenBrush"       Color="{StaticResource StatusGreen}"/>
    <SolidColorBrush x:Key="StatusYellowBrush"      Color="{StaticResource StatusYellow}"/>
    <SolidColorBrush x:Key="StatusRedBrush"         Color="{StaticResource StatusRed}"/>

    <!-- Modal -->
    <SolidColorBrush x:Key="ModalScrimBrush"        Color="{StaticResource ModalScrim}"/>

    <!-- ══════════════════════════════════════════════════════════
         BACKWARD-COMPATIBLE ALIASES
         Existing views reference the old naming convention.
         These aliases forward to the canonical tokens above.
         DO NOT add new colors here — update the canonical section.
         ══════════════════════════════════════════════════════════ -->

    <!-- Background aliases -->
    <Color x:Key="BackgroundPrimaryColor">#FF070B12</Color>
    <Color x:Key="BackgroundSecondaryColor">#FF0F1620</Color>
    <Color x:Key="BackgroundTertiaryColor">#FF16202E</Color>

    <!-- Surface aliases -->
    <Color x:Key="SurfaceColor">#FF1C2A3A</Color>
    <Color x:Key="SurfaceHoverColor">#FF223244</Color>
    <Color x:Key="SurfacePressedColor">#FF293D52</Color>

    <!-- Accent aliases -->
    <Color x:Key="AccentOrangeColor">#FFFF6D1F</Color>
    <Color x:Key="AccentOrangeGlowColor">#FFFF4500</Color>
    <Color x:Key="AccentAmberColor">#FFFFB300</Color>
    <Color x:Key="AccentGoldColor">#FFFFC947</Color>
    <Color x:Key="AccentCyanColor">#FF00D4FF</Color>
    <Color x:Key="AccentCyanDimColor">#FF007EA8</Color>
    <Color x:Key="GlowCyanColor">#FF00E5FF</Color>
    <Color x:Key="AccentPurpleColor">#FF7C4DFF</Color>
    <Color x:Key="GlowPurpleColor">#FFB388FF</Color>
    <Color x:Key="AccentWarmColor">#FFFFB74D</Color>

    <!-- Text aliases -->
    <Color x:Key="TextPrimaryColor">#FFE8ECF4</Color>
    <Color x:Key="TextSecondaryColor">#FF7A8BA8</Color>
    <Color x:Key="TextDisabledColor">#FF344258</Color>
    <Color x:Key="TextAccentColor">#FFFF6D1F</Color>
    <Color x:Key="TextDataColor">#FF00D4FF</Color>
    <Color x:Key="TextErrorColor">#FFFF4444</Color>

    <!-- Border aliases -->
    <Color x:Key="BorderSubtleColor">#FF131E2C</Color>
    <Color x:Key="BorderPrimaryColor">#FF1E2E42</Color>
    <Color x:Key="BorderSecondaryColor">#FF1C2540</Color>
    <Color x:Key="BorderStrongColor">#FF2A3F5C</Color>
    <Color x:Key="BorderAccentColor">#FFFF6D1F</Color>
    <Color x:Key="BorderErrorColor">#FFFF4444</Color>

    <!-- Status aliases -->
    <Color x:Key="StatusGreenColor">#FF22C55E</Color>
    <Color x:Key="StatusYellowColor">#FFFFB300</Color>
    <Color x:Key="StatusRedColor">#FFFF4444</Color>

    <!-- Modal alias -->
    <Color x:Key="ModalScrimColor">#CC000000</Color>

    <!-- Old brush aliases for backward compatibility -->
    <SolidColorBrush x:Key="BackgroundPrimary"  Color="{StaticResource BgPrimary}"/>
    <SolidColorBrush x:Key="BackgroundSecondary" Color="{StaticResource BgSecondary}"/>
    <SolidColorBrush x:Key="BackgroundTertiary"  Color="{StaticResource BgTertiary}"/>
    <SolidColorBrush x:Key="Surface"             Color="{StaticResource BgSurface}"/>
    <SolidColorBrush x:Key="SurfaceHover"        Color="{StaticResource BgSurfaceHover}"/>
    <SolidColorBrush x:Key="SurfacePressed"      Color="{StaticResource BgSurfacePressed}"/>
    <SolidColorBrush x:Key="GlowCyan"            Color="{StaticResource GlowCyanColor}"/>
    <SolidColorBrush x:Key="AccentPurple"        Color="{StaticResource AccentPurpleColor}"/>
    <SolidColorBrush x:Key="GlowPurple"          Color="{StaticResource GlowPurpleColor}"/>
    <SolidColorBrush x:Key="AccentWarm"          Color="{StaticResource AccentWarmColor}"/>
    <SolidColorBrush x:Key="BorderPrimary"       Color="{StaticResource BorderPrimaryColor}"/>
    <SolidColorBrush x:Key="BorderSecondary"     Color="{StaticResource BorderSecondaryColor}"/>

</ResourceDictionary>
