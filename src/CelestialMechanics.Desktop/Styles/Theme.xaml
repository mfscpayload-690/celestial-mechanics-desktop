<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         Theme.xaml — Named Style Variants
         Extends SpaceDarkTheme with application-specific named styles:
         ModeButtonStyle, ControlBarButtonStyle, SpaceTabControlStyle,
         ChartContainerStyle, and all other named button variants.
         ═══════════════════════════════════════════════════════════════ -->

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/CelestialMechanics.Desktop;component/Themes/SpaceDarkTheme.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ══════════════════════════════════════════════════════════
         ModeButtonStyle
         Full-width, 44px height, AccentOrange background,
         BgPrimary text, 600 weight. Hover → AccentOrangeGlow.
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="ModeButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentOrangeBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource BgPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="16,0"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect Color="{StaticResource AccentOrange}"
                                              BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background"
                                    Value="{StaticResource AccentOrangeGlowBrush}"/>
                            <Setter TargetName="bg" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="{StaticResource AccentOrangeGlow}"
                                                      BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Background"
                                    Value="{StaticResource AccentAmberBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         ControlBarButtonStyle
         36px square, transparent bg, BorderBase border,
         icon-only, hover → BgSurfaceHover.
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="ControlBarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBaseBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background"
                                    Value="{StaticResource BgSurfaceHoverBrush}"/>
                            <Setter TargetName="bg" Property="BorderBrush"
                                    Value="{StaticResource AccentOrangeBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Background"
                                    Value="{StaticResource BgSurfacePressedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         ChartContainerStyle
         BgTertiary fill, BorderBase 1px, rx=8,
         for wrapping LiveCharts controls.
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="ChartContainerStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBaseBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         ADDITIONAL NAMED STYLES
         Carried forward from earlier phases for backward compat.
         ══════════════════════════════════════════════════════════ -->

    <!-- Additional cinematic colors for specific UI areas -->
    <Color x:Key="PanelBackgroundColor">#FF161B22</Color>
    <Color x:Key="MenuBarBackgroundColor">#FF11151C</Color>
    <Color x:Key="ControlBarBackgroundColor">#FF1A1F2B</Color>
    <Color x:Key="CyanAccentColor">#FF00C8FF</Color>
    <Color x:Key="ModalOverlayColor">#99000000</Color>
    <Color x:Key="ModalPanelColor">#FF161B22</Color>

    <SolidColorBrush x:Key="PanelBackground"    Color="{StaticResource PanelBackgroundColor}"/>
    <SolidColorBrush x:Key="MenuBarBackground"   Color="{StaticResource MenuBarBackgroundColor}"/>
    <SolidColorBrush x:Key="ControlBarBackground" Color="{StaticResource ControlBarBackgroundColor}"/>
    <SolidColorBrush x:Key="CyanAccent"          Color="{StaticResource CyanAccentColor}"/>
    <SolidColorBrush x:Key="ModalOverlay"        Color="{StaticResource ModalOverlayColor}"/>
    <SolidColorBrush x:Key="ModalPanel"          Color="{StaticResource ModalPanelColor}"/>

    <!-- ── Menu Bar Style ──────────────────────────────────────────── -->
    <Style x:Key="MenuBarStyle" TargetType="Menu">
        <Setter Property="Background" Value="{StaticResource MenuBarBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="MenuBarItemStyle" TargetType="MenuItem">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Padding" Value="10,4"/>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{StaticResource BgSurfaceHoverBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Flat Button (control bar tools) ─────────────────────────── -->
    <Style x:Key="FlatButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="14,6"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background"
                                    Value="{StaticResource BgSurfaceHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Background"
                                    Value="{StaticResource BgSurfaceBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Glow ToggleButton (Play/Pause/Reset) ───────────────────── -->
    <Style x:Key="GlowToggleButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect Color="{StaticResource AccentOrange}"
                                              BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="{StaticResource AccentOrange}"
                                                      BlurRadius="12" ShadowDepth="0" Opacity="0.6"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="border" Property="Background" Value="#15FF6D1F"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#25FF6D1F"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Cyan Slider Style (Time Flow) ──────────────────────────── -->
    <Style x:Key="CyanSliderStyle" TargetType="Slider" BasedOn="{StaticResource {x:Type Slider}}">
        <Setter Property="Minimum" Value="0.1"/>
        <Setter Property="Maximum" Value="10"/>
        <Setter Property="Value" Value="1"/>
        <Setter Property="Width" Value="200"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ── Modal Button Styles ─────────────────────────────────────── -->
    <Style x:Key="ModalPrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentOrangeBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource BgPrimaryBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background"
                                    Value="{StaticResource AccentOrangeGlowBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModalSecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background"
                                    Value="{StaticResource BgSurfaceHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModalExitButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="20,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background"
                                    Value="{StaticResource BgSurfaceBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource StatusRedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Status Bar Compact ──────────────────────────────────────── -->
    <Style x:Key="CompactStatusBarStyle" TargetType="StatusBar">
        <Setter Property="Background" Value="{StaticResource MenuBarBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Height" Value="24"/>
    </Style>

    <!-- ── Body Type Category ToggleButton ── -->
    <Style x:Key="BodyTypeCategoryButtonStyle" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="MinWidth" Value="64"/>
        <Setter Property="Margin" Value="2,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="bg"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource BorderBaseBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel Orientation="Horizontal">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                            <TextBlock Text="▼" FontSize="8" Margin="4,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background"
                                    Value="{StaticResource BgSurfaceHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bg" Property="Background"
                                    Value="{StaticResource BgSurfaceBrush}"/>
                            <Setter TargetName="bg" Property="BorderBrush"
                                    Value="{StaticResource AccentOrangeBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Subtype Card Button ── -->
    <Style x:Key="SubtypeCardStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBaseBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="MinWidth" Value="140"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background"
                                    Value="{StaticResource BgSurfaceHoverBrush}"/>
                            <Setter TargetName="bg" Property="BorderBrush"
                                    Value="{StaticResource AccentOrangeBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Background"
                                    Value="{StaticResource BgTertiaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Modal Navigation Button ── -->
    <Style x:Key="ModalNavButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="15,12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="3,0,0,0"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background"
                                    Value="{StaticResource BgSurfaceHoverBrush}"/>
                            <Setter TargetName="bg" Property="BorderBrush"
                                    Value="{StaticResource AccentOrangeBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Background"
                                    Value="{StaticResource BgTertiaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Modal Navigation Button Accent ── -->
    <Style x:Key="ModalNavButtonAccentStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentOrangeBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource BgPrimaryBrush}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="15,12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Opacity" Value="0.7"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Modal Back Button ── -->
    <Style x:Key="ModalBackButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            <Setter TargetName="bg" Property="Background" Value="#10FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Form Styles ── -->
    <Style x:Key="FormLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style x:Key="FormTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style x:Key="ShortcutHintStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextDisabledBrush}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
    </Style>

    <!-- ── Inspector Styles ── -->
    <Style x:Key="InspectorLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <Style x:Key="InspectorTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="FontFamily" Value="{StaticResource DataFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="MinWidth" Value="60"/>
    </Style>

    <Style x:Key="InspectorCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Margin" Value="0,2"/>
    </Style>

    <Style x:Key="BodyTypePaletteButtonStyle" TargetType="Button" BasedOn="{StaticResource ModeButtonStyle}">
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="MinWidth" Value="64"/>
        <Setter Property="Margin" Value="2,0"/>
        <Setter Property="Height" Value="Auto"/>
    </Style>

    <!-- ── Settings Overlay Background ── -->
    <SolidColorBrush x:Key="SettingsOverlay" Color="#CC000000"/>

    <!-- ══════════════════════════════════════════════════════════
         CompactToolButton — Compact button for bottom toolbar
         Transparent bg, 1px border, TextPrimary text.
         Cyan accent on hover and active states.
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="CompactToolButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBaseBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="#1500D4FF"/>
                            <Setter TargetName="bg" Property="BorderBrush"
                                    Value="{StaticResource AccentCyanBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="#2500D4FF"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         CyanActionButton — Cyan-accented action button (replaces orange)
         For Add Body, Place Body, Apply Config etc.
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="CyanActionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentCyanBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource BgPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="16,0"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect Color="{StaticResource AccentCyan}"
                                              BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="{StaticResource AccentCyan}"
                                                      BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="bg" Property="Background"
                                    Value="{StaticResource AccentCyanDimBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Background"
                                    Value="{StaticResource AccentCyanDimBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
