<UserControl x:Class="CelestialMechanics.Desktop.Views.ViewportPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True">
    <Grid Background="{StaticResource BackgroundPrimary}">
        <Canvas x:Name="ViewportCanvas"
                ClipToBounds="True"
                Background="#FF06090F"/>

        <Border HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="10"
                Padding="8,3"
                Background="#AA111722"
                BorderBrush="{StaticResource BorderBaseBrush}"
                BorderThickness="1"
                CornerRadius="4"
                IsHitTestVisible="False">
            <TextBlock Text="Simulation Viewport"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontFamily="Consolas"
                       FontSize="11"/>
        </Border>
    </Grid>
</UserControl>
