<UserControl x:Class="CelestialMechanics.Desktop.Views.TutorialOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Semi-transparent overlay — does NOT pause the simulation behind it -->
    <Grid Background="#CC000000">
        
        <!-- Centered tutorial card: 480×380, BgSurface, BorderStrong 1px, rx=16 -->
        <Border Width="480" Height="380"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderStrongBrush}"
                BorderThickness="1" CornerRadius="16"
                Padding="32,24">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.6"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Skip + progress dots -->
                    <RowDefinition Height="*"/>      <!-- Content -->
                    <RowDefinition Height="Auto"/>  <!-- Nav buttons -->
                </Grid.RowDefinitions>

                <!-- ═══ Top: Skip + Progress Dots ═══ -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <!-- 5 progress dots: AccentOrange=current, BorderBase=future, StatusGreen=completed -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <!-- Dot 1 -->
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource BorderBaseBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="1">
                                            <Setter Property="Fill" Value="{StaticResource AccentOrangeBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <!-- Dot 2 -->
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource BorderBaseBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                                            <Setter Property="Fill" Value="{StaticResource AccentOrangeBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <!-- Dot 3 -->
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource BorderBaseBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="3">
                                            <Setter Property="Fill" Value="{StaticResource AccentOrangeBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <!-- Dot 4 -->
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource BorderBaseBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4">
                                            <Setter Property="Fill" Value="{StaticResource AccentOrangeBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </StackPanel>

                    <!-- Skip button (top-right) -->
                    <Button Content="SKIP TUTORIAL" HorizontalAlignment="Right"
                            FontSize="11" Cursor="Hand" Command="{Binding SkipCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock x:Name="tb" Text="{TemplateBinding Content}"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="tb" Property="Foreground"
                                                Value="{StaticResource TextPrimaryBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- ═══ Step Content ═══ -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <!-- Visual area -->
                    <Border Height="100" Margin="0,0,0,16"
                            Background="{StaticResource BgTertiaryBrush}"
                            CornerRadius="8">
                        <Grid>
                            <!-- Steps 1,2,3,5: Animated orbiting bodies -->
                            <Canvas x:Name="OrbitCanvas" Width="80" Height="80"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource AccentOrangeBrush}"
                                         Canvas.Left="36" Canvas.Top="36"/>
                                <Ellipse x:Name="OrbitBody1" Width="5" Height="5"
                                         Fill="{StaticResource AccentCyanBrush}"/>
                                <Ellipse x:Name="OrbitBody2" Width="4" Height="4"
                                         Fill="{StaticResource AccentAmberBrush}" Opacity="0.8"/>
                            </Canvas>

                            <!-- Step 4: Integrator comparison table -->
                            <Grid x:Name="IntegratorTable" Visibility="Collapsed" Margin="20,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Headers -->
                                <TextBlock Grid.Column="0" Grid.Row="0" Text="Verlet" FontWeight="SemiBold"
                                           FontSize="13" Foreground="{StaticResource AccentCyanBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Grid.Row="0" Text="Euler" FontWeight="SemiBold"
                                           FontSize="13" Foreground="{StaticResource AccentAmberBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Grid.Row="0" Text="RK4" FontWeight="SemiBold"
                                           FontSize="13" Foreground="{StaticResource AccentOrangeBrush}"
                                           HorizontalAlignment="Center"/>

                                <!-- Type labels -->
                                <TextBlock Grid.Column="0" Grid.Row="1" Text="Symplectic" FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,4"/>
                                <TextBlock Grid.Column="1" Grid.Row="1" Text="Educational" FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,4"/>
                                <TextBlock Grid.Column="2" Grid.Row="1" Text="Precise" FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,4"/>

                                <!-- Energy drift values -->
                                <TextBlock Grid.Column="0" Grid.Row="2" Text="~0.01%" FontSize="12"
                                           Foreground="{StaticResource StatusGreenBrush}"
                                           HorizontalAlignment="Center" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="1" Grid.Row="2" Text="~5.2%" FontSize="12"
                                           Foreground="{StaticResource StatusRedBrush}"
                                           HorizontalAlignment="Center" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="2" Grid.Row="2" Text="~0.1%" FontSize="12"
                                           Foreground="{StaticResource StatusYellowBrush}"
                                           HorizontalAlignment="Center" FontFamily="Consolas"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Title -->
                    <TextBlock Text="{Binding StepTitle}" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>

                    <!-- Body text -->
                    <TextBlock Text="{Binding StepBody}" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" TextAlignment="Center"
                               LineHeight="20" MaxWidth="400"/>
                </StackPanel>

                <!-- ═══ Navigation Buttons ═══ -->
                <Grid Grid.Row="2" Margin="0,16,0,0">
                    <!-- BACK button -->
                    <Button Content="← BACK" HorizontalAlignment="Left"
                            FontSize="13" Cursor="Hand" Command="{Binding BackCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CanGoBack}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent" CornerRadius="8" Padding="16,10">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background"
                                                Value="{StaticResource BgSurfaceHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- NEXT / START SIMULATING button -->
                    <Button Content="{Binding NextButtonText}" HorizontalAlignment="Right"
                            FontSize="13" FontWeight="SemiBold" Foreground="#FF070B12"
                            Cursor="Hand" Command="{Binding NextCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="{StaticResource AccentOrangeBrush}"
                                        CornerRadius="8" Padding="20,10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background"
                                                Value="{StaticResource AccentOrangeGlowBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
