<Window x:Class="CelestialMechanics.Desktop.Views.ModeSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:CelestialMechanics.Desktop.Converters"
        WindowStyle="None"
        WindowState="Maximized"
        AllowsTransparency="True"
        Background="#FF070B12"
        Title="Celestial Mechanics — Mode Select"
        ResizeMode="NoResize">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Window fade-in (400ms, CubicEase) -->
        <Storyboard x:Key="WindowFadeIn">
            <DoubleAnimation Storyboard.TargetName="RootGrid"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{StaticResource BgPrimaryBrush}" Opacity="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>  <!-- Top bar -->
            <RowDefinition Height="*"/>   <!-- Center content -->
            <RowDefinition Height="28"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ BACKGROUND LAYERS ═══ -->
        <Grid Grid.Row="0" Grid.RowSpan="3" IsHitTestVisible="False">
            <!-- Layer 1: Nebula image fallback gradient -->
            <Border x:Name="NebulaFallback">
                <Border.Background>
                    <RadialGradientBrush Center="0.6,0.5" GradientOrigin="0.6,0.5" RadiusX="0.8" RadiusY="0.8">
                        <GradientStop Color="#2A1A00" Offset="0"/>
                        <GradientStop Color="#0A0508" Offset="0.6"/>
                        <GradientStop Color="#000000" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>
            <!-- Layer 1: Nebula image (loaded in code-behind, Opacity=0.22) -->
            <Image x:Name="NebulaImage"
                   Stretch="UniformToFill"
                   Opacity="0.22"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <!-- Layer 2: Radial vignette overlay -->
            <Rectangle>
                <Rectangle.Fill>
                    <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.7" RadiusY="0.7">
                        <GradientStop Color="#00000000" Offset="0.3"/>
                        <GradientStop Color="#AA000000" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>

        <!-- ═══════════════════════════════════════════════════
             TOP BAR — 44px, BgSecondary, persistent across screens
             ═══════════════════════════════════════════════════ -->
        <DockPanel Grid.Row="0" Background="{StaticResource BgSecondaryBrush}">
            <Border DockPanel.Dock="Bottom" Height="1" Background="{StaticResource BorderBaseBrush}"/>

            <!-- Left: App icon + title -->
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                <!-- Orbit/star icon: three orbital paths + central dot -->
                <Canvas Width="16" Height="16" Margin="0,0,8,0">
                    <Ellipse Width="14" Height="8" Canvas.Left="1" Canvas.Top="4"
                             Stroke="{StaticResource AccentOrangeBrush}" StrokeThickness="1" Fill="Transparent"/>
                    <Ellipse Width="8" Height="14" Canvas.Left="4" Canvas.Top="1"
                             Stroke="{StaticResource AccentOrangeBrush}" StrokeThickness="0.8" Fill="Transparent" Opacity="0.6">
                        <Ellipse.RenderTransform>
                            <RotateTransform Angle="30" CenterX="4" CenterY="7"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <Ellipse Width="3" Height="3" Canvas.Left="6.5" Canvas.Top="6.5"
                             Fill="{StaticResource AccentOrangeBrush}"/>
                </Canvas>
                <TextBlock x:Name="TopBarTitle"
                           Text="CELESTIAL MECHANICS" FontSize="13"
                           Foreground="{StaticResource AccentGoldBrush}"
                           VerticalAlignment="Center" FontWeight="Normal"/>
            </StackPanel>

            <!-- Right: Icon buttons (ControlBarButtonStyle, 36px, Segoe MDL2 Assets) -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                <!-- Undo -->
                <Button Content="&#xE7A7;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                        ToolTip="Undo" Style="{StaticResource ControlBarButtonStyle}"/>
                <!-- Redo -->
                <Button Content="&#xE7A6;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                        ToolTip="Redo" Style="{StaticResource ControlBarButtonStyle}"/>

                <!-- Separator -->
                <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBaseBrush}" Margin="4,0"/>

                <!-- Help -->
                <Button Content="&#xE897;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                        ToolTip="Help (Keyboard Shortcuts)" Style="{StaticResource ControlBarButtonStyle}"
                        Command="{Binding ShowHelpCommand}"/>
                <!-- About -->
                <Button Content="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                        ToolTip="About" Style="{StaticResource ControlBarButtonStyle}"
                        Command="{Binding ShowAboutCommand}"/>
                <!-- Settings -->
                <Button Content="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                        ToolTip="Settings" Style="{StaticResource ControlBarButtonStyle}"/>

                <!-- Separator -->
                <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBaseBrush}" Margin="4,0"/>

                <!-- Exit -->
                <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                        ToolTip="Exit" Style="{StaticResource ControlBarButtonStyle}"
                        Command="{Binding ExitAppCommand}"/>
            </StackPanel>

            <!-- Spacer fill -->
            <Border/>
        </DockPanel>

        <!-- ═══════════════════════════════════════════════════
             CENTER: Mode Cards — 220×280, 32px gap
             ═══════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Center" VerticalAlignment="Center">

            <!-- ── Card 1: SIMULATION ── -->
            <Border x:Name="SimCard" Width="220" Height="280"
                    Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderBaseBrush}"
                    BorderThickness="1" CornerRadius="16"
                    Margin="0,0,32,0" Cursor="Hand">
                <Border.Effect>
                    <DropShadowEffect x:Name="SimGlow" Color="{StaticResource AccentOrangeGlow}"
                                      BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                </Border.Effect>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="SimGlow"
                                                 Storyboard.TargetProperty="BlurRadius"
                                                 To="24" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="SimGlow"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0.6" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="SimGlow"
                                                 Storyboard.TargetProperty="BlurRadius"
                                                 To="0" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="SimGlow"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>

                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="80"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Orbit icon: three ellipses in different orbital planes -->
                    <Canvas Grid.Row="0" Width="60" Height="60" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse Width="50" Height="30" Canvas.Left="5" Canvas.Top="15"
                                 Stroke="{StaticResource AccentOrangeBrush}" StrokeThickness="1.5" Fill="Transparent"/>
                        <Ellipse Width="30" Height="50" Canvas.Left="15" Canvas.Top="5"
                                 Stroke="{StaticResource AccentOrangeBrush}" StrokeThickness="1.2" Fill="Transparent"
                                 Opacity="0.7">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="30" CenterX="15" CenterY="25"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse Width="40" Height="20" Canvas.Left="10" Canvas.Top="20"
                                 Stroke="{StaticResource AccentOrangeBrush}" StrokeThickness="0.8" Fill="Transparent"
                                 Opacity="0.4">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="-20" CenterX="20" CenterY="10"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <!-- Central body -->
                        <Ellipse Width="6" Height="6" Canvas.Left="27" Canvas.Top="27"
                                 Fill="{StaticResource AccentOrangeBrush}"/>
                    </Canvas>

                    <TextBlock Grid.Row="1" Text="SIMULATION" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="2" Text="Run &amp; analyze N-body&#x0a;gravitational systems"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               Margin="0,6,0,0" LineHeight="18"/>

                    <Button Grid.Row="4" Content="LAUNCH →"
                            Style="{StaticResource ModeButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Command="{Binding LaunchSimulationCommand}"/>
                </Grid>
            </Border>

            <!-- ── Card 2: OBSERVATION (DISABLED) ── -->
            <Border Width="220" Height="280"
                    Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderBaseBrush}"
                    BorderThickness="1" CornerRadius="16"
                    Margin="0,0,32,0" Opacity="0.5"
                    IsEnabled="False">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="80"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- PHASE 3 badge -->
                    <Border Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="{StaticResource BgTertiaryBrush}"
                            CornerRadius="4" Padding="6,2" Margin="-4,-4,0,0">
                        <TextBlock Text="PHASE 3" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>

                    <!-- Telescope icon (SVG path) -->
                    <Canvas Grid.Row="0" Width="60" Height="60" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Data="M 15 45 L 30 15 L 35 17 L 22 43 Z"
                              Fill="{StaticResource TextDisabledBrush}" Opacity="0.6"/>
                        <Path Data="M 25 20 L 45 10 L 48 16 L 28 26 Z"
                              Fill="{StaticResource TextDisabledBrush}" Opacity="0.4"/>
                        <Ellipse Width="8" Height="8" Canvas.Left="42" Canvas.Top="8"
                                 Stroke="{StaticResource TextDisabledBrush}" StrokeThickness="1" Fill="Transparent"/>
                        <!-- Tripod legs -->
                        <Line X1="20" Y1="42" X2="10" Y2="55"
                              Stroke="{StaticResource TextDisabledBrush}" StrokeThickness="1.5"/>
                        <Line X1="22" Y1="43" X2="30" Y2="55"
                              Stroke="{StaticResource TextDisabledBrush}" StrokeThickness="1.5"/>
                    </Canvas>

                    <TextBlock Grid.Row="1" Text="OBSERVATION" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextDisabledBrush}" HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="2" Text="Browse star catalogs&#x0a;and real sky data"
                               FontSize="12" Foreground="{StaticResource TextDisabledBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               Margin="0,6,0,0" LineHeight="18"/>

                    <TextBlock Grid.Row="4" Text="COMING SOON"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextDisabledBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Height="44" Padding="0,12"/>
                </Grid>
            </Border>

            <!-- ── Card 3: EXIT ── -->
            <Border x:Name="ExitCard" Width="220" Height="280"
                    Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderBaseBrush}"
                    BorderThickness="1" CornerRadius="16"
                    Cursor="Hand">
                <Border.Effect>
                    <DropShadowEffect x:Name="ExitGlow" Color="{StaticResource StatusRed}"
                                      BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                </Border.Effect>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="ExitGlow"
                                                 Storyboard.TargetProperty="BlurRadius"
                                                 To="20" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="ExitGlow"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0.5" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="ExitGlow"
                                                 Storyboard.TargetProperty="BlurRadius"
                                                 To="0" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="ExitGlow"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>

                <Grid Margin="20" x:Name="ExitCardGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="80"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Power icon (SVG path) -->
                    <Canvas Grid.Row="0" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Power circle (open top) -->
                        <Path Data="M 8 12 A 14 14 0 1 0 32 12"
                              Stroke="{StaticResource StatusRedBrush}" StrokeThickness="2.5"
                              Fill="Transparent"/>
                        <!-- Power line (top bar) -->
                        <Line X1="20" Y1="2" X2="20" Y2="18"
                              Stroke="{StaticResource StatusRedBrush}" StrokeThickness="2.5"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Canvas>

                    <TextBlock Grid.Row="1" Text="EXIT" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource StatusRedBrush}" HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="2" Text="Close the application"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               Margin="0,6,0,0"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- ═══ NOTIFICATION SNACKBAR ═══ -->
        <Border Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,40" CornerRadius="8"
                Background="{StaticResource BgSurfaceBrush}" Padding="16,10"
                Visibility="{Binding ShowCopiedNotification, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding CopiedMessage}" FontSize="13"
                       Foreground="{StaticResource AccentCyanBrush}"/>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             BOTTOM STATUS BAR — 28px, BgSecondary
             ═══════════════════════════════════════════════════ -->
        <DockPanel Grid.Row="2" Background="{StaticResource BgSecondaryBrush}">
            <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource BorderBaseBrush}"/>

            <!-- Left: Copyright -->
            <TextBlock DockPanel.Dock="Left" Text="© 2026 Celestial Mechanics Team"
                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center" Margin="12,0,0,0"/>

            <!-- Right: Version -->
            <TextBlock DockPanel.Dock="Right" Text="v1.0.0-alpha"
                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center" Margin="0,0,12,0"/>

            <!-- Center: Clickable email -->
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="11" Foreground="{StaticResource AccentCyanBrush}"
                       Cursor="Hand" ToolTip="Click to copy to clipboard"
                       x:Name="EmailLink" Text="celestial1mechanics@gmail.com"/>
        </DockPanel>
    </Grid>
</Window>
