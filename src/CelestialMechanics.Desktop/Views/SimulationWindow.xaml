<Window x:Class="CelestialMechanics.Desktop.Views.SimulationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CelestialMechanics.Desktop.Views"
        WindowStyle="None"
        WindowState="Maximized"
        AllowsTransparency="True"
        Background="#FF070B12"
        Title="Celestial Mechanics — Launch"
        ResizeMode="NoResize">

    <!-- ═══════════════════════════════════════════════════
         LIGHTWEIGHT OVERLAY HOST
         Welcome → Tutorial (first-time) → Project Hub → then opens MainWindow backend
         ═══════════════════════════════════════════════════ -->

    <Grid x:Name="RootGrid" Background="{StaticResource BgPrimaryBrush}">

        <!-- Starfield canvas — procedural twinkling stars for visual backdrop -->
        <Canvas x:Name="StarCanvas" IsHitTestVisible="False"/>

        <!-- Subtle radial vignette overlay for depth -->
        <Border IsHitTestVisible="False">
            <Border.Background>
                <RadialGradientBrush Center="0.5,0.5" RadiusX="0.7" RadiusY="0.7">
                    <GradientStop Color="Transparent" Offset="0"/>
                    <GradientStop Color="#40070B12" Offset="0.85"/>
                    <GradientStop Color="#AA070B12" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <!-- ═══ WELCOME OVERLAY (top layer) ═══ -->
        <Grid x:Name="WelcomeLayer" Panel.ZIndex="100">
            <views:WelcomeOverlay x:Name="WelcomeOverlayControl"/>
        </Grid>

        <!-- ═══ TUTORIAL OVERLAY ═══ -->
        <Grid x:Name="TutorialLayer" Panel.ZIndex="50" Visibility="Collapsed">
            <views:TutorialOverlay x:Name="TutorialOverlayControl"/>
        </Grid>

        <!-- ═══ PROJECT HUB OVERLAY ═══ -->
        <Grid x:Name="ProjectHubLayer" Panel.ZIndex="75" Visibility="Collapsed">
            <views:ProjectHubOverlay x:Name="ProjectHubControl"/>
        </Grid>
    </Grid>
</Window>
