<UserControl x:Class="CelestialMechanics.Desktop.Views.ProjectHubOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CelestialMechanics.Desktop.ViewModels">

    <!-- ═══════════════════════════════════════════════════
         PROJECT HUB OVERLAY
         Displayed after tutorial (first-time) or welcome (returning).
         Shows New Project creation, recent projects list, and Exit.
         ═══════════════════════════════════════════════════ -->

    <UserControl.Resources>
        <!-- Fade-in storyboard -->
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetName="HubRoot"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="HubCardTransform"
                             Storyboard.TargetProperty="Y"
                             From="20" To="0" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <QuinticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Project item hover style -->
        <Style x:Key="ProjectItemBorder" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BgSurfaceHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource BorderBaseBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- Semi-transparent backdrop -->
    <Grid x:Name="HubRoot" Background="#CC000000" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="HubCardTransform" Y="20"/>
        </Grid.RenderTransform>

        <!-- ═══ Central Hub Card ═══ -->
        <Border Width="620" MaxHeight="560"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderStrongBrush}"
                BorderThickness="1" CornerRadius="16"
                Padding="0">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="48" ShadowDepth="0" Opacity="0.7"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>    <!-- Header -->
                    <RowDefinition Height="Auto"/>    <!-- New Project section -->
                    <RowDefinition Height="*"/>       <!-- Recent Projects -->
                    <RowDefinition Height="Auto"/>    <!-- Footer (Exit) -->
                </Grid.RowDefinitions>

                <!-- ═══ HEADER ═══ -->
                <Border Grid.Row="0" Padding="28,22,28,16">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Orbit icon -->
                            <Canvas Width="22" Height="22" Margin="0,0,10,0">
                                <Ellipse Width="18" Height="10" Canvas.Left="2" Canvas.Top="6"
                                         Stroke="{StaticResource AccentOrangeBrush}" StrokeThickness="1.2" Fill="Transparent"/>
                                <Ellipse Width="10" Height="18" Canvas.Left="6" Canvas.Top="2"
                                         Stroke="{StaticResource AccentOrangeBrush}" StrokeThickness="1" Fill="Transparent" Opacity="0.6">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform Angle="30" CenterX="5" CenterY="9"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                                <Ellipse Width="4" Height="4" Canvas.Left="9" Canvas.Top="9"
                                         Fill="{StaticResource AccentOrangeBrush}"/>
                            </Canvas>
                            <TextBlock Text="PROJECT HUB" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentGoldBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Version badge -->
                        <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="{StaticResource BgTertiaryBrush}"
                                CornerRadius="4" Padding="8,3">
                            <TextBlock Text="v1.0.0-alpha" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Separator -->
                <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                           Fill="{StaticResource BorderBaseBrush}"/>

                <!-- ═══ NEW PROJECT SECTION ═══ -->
                <Border Grid.Row="1" Padding="28,20,28,16">
                    <StackPanel>
                        <TextBlock Text="NEW PROJECT" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Project name input -->
                            <Border Grid.Column="0" Background="{StaticResource BgTertiaryBrush}"
                                    BorderBrush="{StaticResource BorderBaseBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="2" Margin="0,0,10,0">
                                <TextBox x:Name="ProjectNameInput"
                                         Text="{Binding NewProjectName, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="13" FontFamily="Segoe UI"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         CaretBrush="{StaticResource AccentOrangeBrush}"
                                         Background="Transparent" BorderThickness="0"
                                         Padding="10,8" VerticalContentAlignment="Center"
                                         KeyDown="OnProjectNameKeyDown">
                                    <!-- Placeholder text via adorner -->
                                </TextBox>
                            </Border>

                            <!-- Placeholder overlay (visible when input is empty) -->
                            <TextBlock Grid.Column="0" Text="Enter project name…"
                                       FontSize="13" FontFamily="Segoe UI"
                                       Foreground="{StaticResource TextDisabledBrush}"
                                       VerticalAlignment="Center" Margin="14,0,0,0"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding NewProjectName}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Create button -->
                            <Button Grid.Column="1" Content="CREATE PROJECT"
                                    FontSize="12" FontWeight="SemiBold"
                                    Foreground="#FF070B12" Cursor="Hand"
                                    Command="{Binding CreateProjectCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="{StaticResource AccentOrangeBrush}"
                                                CornerRadius="8" Padding="18,9"
                                                BorderBrush="{StaticResource AccentOrangeBrush}"
                                                BorderThickness="1">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background"
                                                        Value="{StaticResource AccentOrangeGlowBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="bg" Property="Background"
                                                        Value="{StaticResource BgTertiaryBrush}"/>
                                                <Setter TargetName="bg" Property="BorderBrush"
                                                        Value="{StaticResource BorderBaseBrush}"/>
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource TextDisabledBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Separator -->
                <Rectangle Grid.Row="1" Height="1" VerticalAlignment="Bottom"
                           Fill="{StaticResource BorderBaseBrush}"/>

                <!-- ═══ RECENT PROJECTS SECTION ═══ -->
                <Border Grid.Row="2" Padding="28,16,28,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="RECENT PROJECTS" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,10"/>

                        <!-- Projects list -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="0,0,4,0">
                            <ItemsControl ItemsSource="{Binding RecentProjects}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ProjectItemBorder}"
                                                MouseLeftButtonUp="OnProjectClicked"
                                                Tag="{Binding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Folder icon -->
                                                <TextBlock Grid.Column="0" Text="&#xE8B7;"
                                                           FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                           Foreground="{StaticResource AccentAmberBrush}"
                                                           VerticalAlignment="Center" Margin="0,0,12,0"/>

                                                <!-- Project name + path -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Path}" FontSize="10"
                                                               Foreground="{StaticResource TextDisabledBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <!-- Date -->
                                                <TextBlock Grid.Column="2"
                                                           FontSize="11" FontFamily="Consolas"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" Margin="12,0,0,0"
                                                           x:Name="DateText"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Empty state overlay -->
                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Margin="0,20,0,20">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasProjects}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <!-- Empty folder icon -->
                            <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                                       Foreground="{StaticResource TextDisabledBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="No projects yet" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="Create your first project to get started"
                                       FontSize="12"
                                       Foreground="{StaticResource TextDisabledBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══ FOOTER ═══ -->
                <Border Grid.Row="3" Padding="28,12,28,18">
                    <Grid>
                        <!-- Separator at top -->
                        <Rectangle Height="1" VerticalAlignment="Top" Margin="0,-12,0,0"
                                   Fill="{StaticResource BorderBaseBrush}"/>

                        <!-- Left: Keyboard shortcut hint -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                    HorizontalAlignment="Left">
                            <TextBlock Text="Ctrl+S" FontSize="10" FontFamily="Consolas"
                                       Foreground="{StaticResource TextDisabledBrush}"
                                       Margin="0,0,4,0"/>
                            <TextBlock Text="Save" FontSize="10"
                                       Foreground="{StaticResource TextDisabledBrush}"
                                       Margin="0,0,12,0"/>
                            <TextBlock Text="Space" FontSize="10" FontFamily="Consolas"
                                       Foreground="{StaticResource TextDisabledBrush}"
                                       Margin="0,0,4,0"/>
                            <TextBlock Text="Play/Pause" FontSize="10"
                                       Foreground="{StaticResource TextDisabledBrush}"/>
                        </StackPanel>

                        <!-- Right: Exit button -->
                        <Button Content="EXIT" HorizontalAlignment="Right"
                                FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                                Command="{Binding ExitAppCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent"
                                            CornerRadius="8" Padding="20,9"
                                            BorderBrush="{StaticResource StatusRedBrush}"
                                            BorderThickness="1">
                                        <TextBlock Text="{TemplateBinding Content}"
                                                   Foreground="{StaticResource StatusRedBrush}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background"
                                                    Value="#33FF3B4F"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
