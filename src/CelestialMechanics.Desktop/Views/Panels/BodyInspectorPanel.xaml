<UserControl x:Class="CelestialMechanics.Desktop.Views.Panels.BodyInspectorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CelestialMechanics.Desktop.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
    </UserControl.Resources>

    <DockPanel Background="{StaticResource BgSecondaryBrush}">

        <!-- ── Panel Header ── -->
        <Border DockPanel.Dock="Top"
                Style="{StaticResource PanelHeaderBorderStyle}">
            <TextBlock Text="INSPECTOR"
                       Style="{StaticResource PanelHeaderTextStyle}"/>
        </Border>

        <!-- ── Empty State ── -->
        <TextBlock Text="Select a body to inspect"
                   Foreground="{StaticResource TextDisabledBrush}"
                   FontSize="12" FontStyle="Italic"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="0,40,0,0"
                   Visibility="{Binding HasSelection,
                                Converter={StaticResource InverseBoolToVis}}"/>

        <!-- ── Inspector Content ── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding HasSelection,
                                   Converter={StaticResource BoolToVis}}">
            <StackPanel Margin="8">

                <!-- ── IDENTITY ── -->
                <GroupBox Header="IDENTITY"
                          Style="{StaticResource InspectorGroupBoxStyle}">
                    <StackPanel>
                        <TextBlock Text="Name"
                                   Style="{StaticResource InspectorLabelStyle}"/>
                        <TextBox Text="{Binding BodyName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                 Style="{StaticResource InspectorTextBoxStyle}"
                                 MaxLength="64"
                                 Margin="0,0,0,6"/>

                        <TextBlock Text="Type"
                                   Style="{StaticResource InspectorLabelStyle}"/>
                        <TextBlock Text="{Binding BodyType}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="Consolas" FontSize="11"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="ID"
                                   Style="{StaticResource InspectorLabelStyle}"/>
                        <TextBlock Text="{Binding BodyId}"
                                   Foreground="{StaticResource AccentCyanBrush}"
                                   FontFamily="Consolas" FontSize="11"/>
                    </StackPanel>
                </GroupBox>

                <!-- ── POSITION ── -->
                <GroupBox Header="POSITION"
                          Style="{StaticResource InspectorGroupBoxStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="X"
                                   Style="{StaticResource InspectorLabelStyle}"/>
                        <TextBox   Grid.Row="0" Grid.Column="1"
                                   Text="{Binding PositionX, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F6}"
                                   Style="{StaticResource InspectorTextBoxStyle}"
                                   Foreground="{StaticResource TextDataBrush}" Margin="0,0,0,2"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Y"
                                   Style="{StaticResource InspectorLabelStyle}"/>
                        <TextBox   Grid.Row="1" Grid.Column="1"
                                   Text="{Binding PositionY, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F6}"
                                   Style="{StaticResource InspectorTextBoxStyle}"
                                   Foreground="{StaticResource TextDataBrush}" Margin="0,0,0,2"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Z"
                                   Style="{StaticResource InspectorLabelStyle}"/>
                        <TextBox   Grid.Row="2" Grid.Column="1"
                                   Text="{Binding PositionZ, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F6}"
                                   Style="{StaticResource InspectorTextBoxStyle}"
                                   Foreground="{StaticResource TextDataBrush}"/>
                    </Grid>
                </GroupBox>

                <!-- ── VELOCITY ── -->
                <GroupBox Header="VELOCITY"
                          Style="{StaticResource InspectorGroupBoxStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="X"
                                   Style="{StaticResource InspectorLabelStyle}"/>
                        <TextBox   Grid.Row="0" Grid.Column="1"
                                   Text="{Binding VelocityX, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F6}"
                                   Style="{StaticResource InspectorTextBoxStyle}"
                                   Foreground="{StaticResource TextDataBrush}" Margin="0,0,0,2"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Y"
                                   Style="{StaticResource InspectorLabelStyle}"/>
                        <TextBox   Grid.Row="1" Grid.Column="1"
                                   Text="{Binding VelocityY, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F6}"
                                   Style="{StaticResource InspectorTextBoxStyle}"
                                   Foreground="{StaticResource TextDataBrush}" Margin="0,0,0,2"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Z"
                                   Style="{StaticResource InspectorLabelStyle}"/>
                        <TextBox   Grid.Row="2" Grid.Column="1"
                                   Text="{Binding VelocityZ, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F6}"
                                   Style="{StaticResource InspectorTextBoxStyle}"
                                   Foreground="{StaticResource TextDataBrush}"/>
                    </Grid>
                </GroupBox>

                <!-- ── PHYSICAL ── -->
                <GroupBox Header="PHYSICAL"
                          Style="{StaticResource InspectorGroupBoxStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Mass"
                                   Style="{StaticResource InspectorLabelStyle}"/>
                        <TextBox   Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Mass, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=G6}"
                                   Style="{StaticResource InspectorTextBoxStyle}" Margin="0,0,0,2"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Radius"
                                   Style="{StaticResource InspectorLabelStyle}"/>
                        <TextBox   Grid.Row="1" Grid.Column="1"
                                   Text="{Binding Radius, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=G6}"
                                   Style="{StaticResource InspectorTextBoxStyle}" Margin="0,0,0,2"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Density"
                                   Style="{StaticResource InspectorLabelStyle}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding Density, StringFormat=G6}"
                                   Foreground="{StaticResource TextDisabledBrush}"
                                   FontFamily="Consolas" FontSize="11"
                                   VerticalAlignment="Center"/>

                        <!-- Schwarzschild radius (Black Hole only) -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Schwarzschild"
                                   Style="{StaticResource InspectorLabelStyle}"
                                   Visibility="{Binding IsBlackHole, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Text="{Binding SchwarzschildRadius, StringFormat=G4}"
                                   Foreground="{StaticResource AccentCyanBrush}"
                                   FontFamily="Consolas" FontSize="11"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsBlackHole, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                </GroupBox>

                <!-- ── ORBITAL ELEMENTS ── -->
                <GroupBox Header="ORBITAL ELEMENTS"
                          Style="{StaticResource InspectorGroupBoxStyle}"
                          Visibility="{Binding ShowOrbitalElements,
                                       Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Central Body"
                                   Style="{StaticResource InspectorLabelStyle}"/>
                        <TextBlock Text="{Binding CentralBodyName}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="Consolas" FontSize="11"
                                   Margin="0,0,0,4"/>

                        <TextBlock Text="Orbit Type"
                                   Style="{StaticResource InspectorLabelStyle}"/>
                        <TextBlock Text="{Binding OrbitType}"
                                   Foreground="{StaticResource AccentCyanBrush}"
                                   FontFamily="Consolas" FontSize="11"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="a (Semi-major)"
                                       Style="{StaticResource InspectorLabelStyle}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding SemiMajorAxis, StringFormat=G5}"
                                       Foreground="{StaticResource TextDataBrush}"
                                       FontFamily="Consolas" FontSize="11"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="e (Eccentricity)"
                                       Style="{StaticResource InspectorLabelStyle}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding Eccentricity, StringFormat=F6}"
                                       Foreground="{StaticResource TextDataBrush}"
                                       FontFamily="Consolas" FontSize="11"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="i (Inclination)"
                                       Style="{StaticResource InspectorLabelStyle}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding Inclination, StringFormat=F2}"
                                       Foreground="{StaticResource TextDataBrush}"
                                       FontFamily="Consolas" FontSize="11"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Period"
                                       Style="{StaticResource InspectorLabelStyle}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1"
                                       Text="{Binding OrbitalPeriod, StringFormat=G5}"
                                       Foreground="{StaticResource TextDataBrush}"
                                       FontFamily="Consolas" FontSize="11"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- ── Apply Button ── -->
                <Button Content="Apply Changes"
                        Style="{StaticResource GlowToggleButtonStyle}"
                        Command="{Binding ApplyChangesCommand}"
                        HorizontalAlignment="Stretch"
                        Margin="0,4,0,0"/>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
