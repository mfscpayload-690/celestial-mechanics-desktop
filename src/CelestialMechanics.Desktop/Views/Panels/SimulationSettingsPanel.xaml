<UserControl x:Class="CelestialMechanics.Desktop.Views.Panels.SimulationSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CelestialMechanics.Desktop.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <DockPanel Background="{StaticResource BgSecondaryBrush}">

        <!-- Panel Header -->
        <Border DockPanel.Dock="Top"
                Style="{StaticResource PanelHeaderBorderStyle}">
            <TextBlock Text="PHYSICS"
                       Style="{StaticResource PanelHeaderTextStyle}"/>
        </Border>

        <!-- Footer: Apply -->
        <Border DockPanel.Dock="Bottom" Padding="8,6">
            <Button Content="APPLY CONFIG"
                    Style="{StaticResource CyanActionButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Command="{Binding ApplyCommand}"/>
        </Border>

        <!-- Scrollable Settings -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="8">

                <!-- INTEGRATOR -->
                <GroupBox Header="INTEGRATOR"
                          Style="{StaticResource InspectorGroupBoxStyle}">
                    <StackPanel>
                        <TextBlock Text="Method"
                                   Style="{StaticResource InspectorLabelStyle}" Margin="0,0,0,4"/>
                        <RadioButton Content="Verlet (recommended)"
                                     IsChecked="{Binding IsVerlet, Mode=TwoWay}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     Margin="0,0,0,3"/>
                        <RadioButton Content="Euler"
                                     IsChecked="{Binding IsEuler, Mode=TwoWay}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     Margin="0,0,0,3"/>
                        <RadioButton Content="Runge-Kutta 4 (RK4)"
                                     IsChecked="{Binding IsRK4, Mode=TwoWay}"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </GroupBox>

                <!-- TIMESTEP -->
                <GroupBox Header="TIMESTEP"
                          Style="{StaticResource InspectorGroupBoxStyle}">
                    <StackPanel>
                        <TextBlock Text="dt"
                                   Style="{StaticResource InspectorLabelStyle}" Margin="0,0,0,2"/>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding TimeStep, StringFormat=G4}"
                                       Foreground="{StaticResource TextDataBrush}"
                                       FontFamily="Consolas" FontSize="11"
                                       VerticalAlignment="Center" MinWidth="50"
                                       TextAlignment="Right" Margin="8,0,0,0"/>
                            <Slider Value="{Binding TimeStep, Mode=TwoWay}"
                                    Minimum="0.0001" Maximum="0.01"
                                    TickFrequency="0.0001"
                                    IsSnapToTickEnabled="False"
                                    VerticalAlignment="Center"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

                <!-- SOFTENING -->
                <GroupBox Header="SOFTENING"
                          Style="{StaticResource InspectorGroupBoxStyle}">
                    <StackPanel>
                        <TextBlock Text="Epsilon"
                                   Style="{StaticResource InspectorLabelStyle}" Margin="0,0,0,2"/>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding SofteningEpsilon, StringFormat=G4}"
                                       Foreground="{StaticResource TextDataBrush}"
                                       FontFamily="Consolas" FontSize="11"
                                       VerticalAlignment="Center" MinWidth="50"
                                       TextAlignment="Right" Margin="8,0,0,0"/>
                            <Slider Value="{Binding SofteningEpsilon, Mode=TwoWay}"
                                    Minimum="0.001" Maximum="1.0"
                                    TickFrequency="0.001"
                                    IsSnapToTickEnabled="False"
                                    VerticalAlignment="Center"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

                <!-- PERFORMANCE -->
                <GroupBox Header="PERFORMANCE"
                          Style="{StaticResource InspectorGroupBoxStyle}">
                    <StackPanel>
                        <CheckBox Content="SoA Data Path"
                                  IsChecked="{Binding UseSoAPath, Mode=TwoWay}"
                                  Style="{StaticResource InspectorCheckBoxStyle}"/>
                        <CheckBox Content="Parallel Computation"
                                  IsChecked="{Binding UseParallelComputation, Mode=TwoWay}"
                                  Style="{StaticResource InspectorCheckBoxStyle}"/>
                        <CheckBox Content="Deterministic Mode"
                                  IsChecked="{Binding DeterministicMode, Mode=TwoWay}"
                                  Style="{StaticResource InspectorCheckBoxStyle}"/>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
