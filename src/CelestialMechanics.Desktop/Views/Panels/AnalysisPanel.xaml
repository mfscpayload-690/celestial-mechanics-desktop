<UserControl x:Class="CelestialMechanics.Desktop.Views.Panels.AnalysisPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CelestialMechanics.Desktop.Converters"
             Background="{StaticResource BgSecondaryBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:StatusColorConverter x:Key="StatusColorConv"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>  <!-- Collapse header -->
            <RowDefinition Height="*"/>   <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ══ Collapse/Expand header bar ══ -->
        <DockPanel Grid.Row="0" Background="{StaticResource BgTertiaryBrush}" Cursor="Hand"
                   MouseLeftButtonUp="OnToggleCollapse">
            <Border DockPanel.Dock="Bottom" Height="1"
                    Background="{StaticResource BorderBaseBrush}"/>
            <TextBlock DockPanel.Dock="Left" Text="ANALYSIS"
                       Style="{StaticResource PanelHeaderTextStyle}"
                       Margin="12,0,0,0" VerticalAlignment="Center"/>
            <TextBlock x:Name="CollapseIcon" DockPanel.Dock="Right"
                       Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center" Margin="0,0,12,0"
                       RenderTransformOrigin="0.5,0.5">
                <TextBlock.RenderTransform>
                    <RotateTransform x:Name="CollapseRotation" Angle="0"/>
                </TextBlock.RenderTransform>
            </TextBlock>
            <Border/> <!-- Spacer -->
        </DockPanel>

        <!-- ══ Content (collapsible) ══ -->
        <Grid Grid.Row="1" x:Name="AnalysisContent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>  <!-- Energy chart (60%) -->
                <ColumnDefinition Width="4"/>   <!-- Splitter -->
                <ColumnDefinition Width="2*"/>  <!-- Event log (40%) -->
            </Grid.ColumnDefinitions>

            <!-- ═══ LEFT: Energy Chart ═══ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Sub-header + legend -->
                <DockPanel Grid.Row="0" Margin="8,2,8,0">
                    <TextBlock DockPanel.Dock="Left" Text="ENERGY"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource AccentOrangeBrush}" Margin="0,0,3,0"/>
                        <TextBlock Text="Total" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                        <Ellipse Width="6" Height="6" Fill="{StaticResource AccentAmberBrush}" Margin="0,0,3,0"/>
                        <TextBlock Text="Kinetic" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                        <Ellipse Width="6" Height="6" Fill="{StaticResource AccentCyanBrush}" Margin="0,0,3,0"/>
                        <TextBlock Text="Potential" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <Border/>
                </DockPanel>

                <!-- Chart area (Canvas rendering — lightweight approach) -->
                <Border Grid.Row="1" Background="{StaticResource BgTertiaryBrush}"
                        Margin="8,2,4,8" CornerRadius="4"
                        Style="{StaticResource ChartContainerStyle}">
                    <Canvas x:Name="ChartCanvas" ClipToBounds="True" Margin="4"/>
                </Border>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4"
                          Background="{StaticResource BorderBaseBrush}"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <!-- ═══ RIGHT: Event Log ═══ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="EVENT LOG"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="8,2,0,0"/>

                <!-- Event list -->
                <ListView Grid.Row="1"
                          ItemsSource="{Binding EventLog}"
                          Background="Transparent"
                          BorderThickness="0"
                          Margin="4,0,4,4"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Type badge -->
                                <Border Grid.Column="0" CornerRadius="3" Padding="5,1"
                                        Margin="0,0,6,0" VerticalAlignment="Center"
                                        Background="{StaticResource BgTertiaryBrush}">
                                    <TextBlock Text="{Binding Type}" FontSize="9"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding TypeColor, Converter={StaticResource StatusColorConv}}"/>
                                </Border>

                                <!-- Message -->
                                <TextBlock Grid.Column="1" Text="{Binding Message}"
                                           FontSize="11" Foreground="{StaticResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>

                                <!-- UTC timestamp -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Timestamp, StringFormat=HH:mm:ss}"
                                           FontSize="9" FontFamily="Consolas"
                                           Foreground="{StaticResource TextDisabledBrush}"
                                           Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{StaticResource BgSurfaceHoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
