<UserControl x:Class="CelestialMechanics.Desktop.Views.Modals.FileMenuModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="420" Height="420"
            Background="{StaticResource ModalPanel}"
            CornerRadius="16"
            BorderBrush="{StaticResource BorderPrimary}"
            BorderThickness="1"
            Padding="28,24">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="FILE"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource CyanAccent}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>

            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <Button Content="New Simulation"
                        Style="{StaticResource ModalSecondaryButtonStyle}"
                        Command="{Binding NewSimulationCommand}"
                        Margin="0,0,0,10"/>

                <Button Content="Open"
                        Style="{StaticResource ModalSecondaryButtonStyle}"
                        Command="{Binding OpenCommand}"
                        Margin="0,0,0,10"/>

                <Button Content="Save"
                        Style="{StaticResource ModalPrimaryButtonStyle}"
                        Command="{Binding SaveCommand}"
                        Margin="0,0,0,10"/>

                <Button Content="Exit Application"
                        Style="{StaticResource ModalSecondaryButtonStyle}"
                        Command="{Binding ExitCommand}"/>
            </StackPanel>

            <Button Grid.Row="2"
                    Content="Back"
                    Style="{StaticResource ModalBackButtonStyle}"
                    Command="{Binding BackCommand}"
                    HorizontalAlignment="Center"
                    Margin="0,12,0,0"/>
        </Grid>
    </Border>
</UserControl>
