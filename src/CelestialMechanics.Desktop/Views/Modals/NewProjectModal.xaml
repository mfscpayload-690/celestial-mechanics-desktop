<UserControl x:Class="CelestialMechanics.Desktop.Views.Modals.NewProjectModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- New Project: Name + Location form -->
    <Border HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="400" Height="350"
            Background="{StaticResource ModalPanel}"
            CornerRadius="16"
            BorderBrush="{StaticResource BorderPrimary}"
            BorderThickness="1"
            Padding="24,0">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0"
                       Text="NEW PROJECT"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource CyanAccent}"
                       HorizontalAlignment="Center"
                       Margin="0,22,0,20"/>

            <!-- Form -->
            <StackPanel Grid.Row="1" VerticalAlignment="Top">
                <!-- Project Name -->
                <TextBlock Text="Project Name"
                           Style="{StaticResource FormLabelStyle}"/>
                <Grid Margin="0,0,0,18">
                    <TextBox x:Name="ProjectNameBox"
                             Style="{StaticResource FormTextBoxStyle}"
                             Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"/>
                    <!-- Watermark -->
                    <TextBlock Text="Enter project name..."
                               FontSize="13"
                               Foreground="{StaticResource TextDisabledBrush}"
                               Padding="12,9"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=ProjectNameBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Location -->
                <TextBlock Text="Location"
                           Style="{StaticResource FormLabelStyle}"/>
                <DockPanel Margin="0,0,0,0">
                    <Button Content="Browse"
                            DockPanel.Dock="Right"
                            Style="{StaticResource ModalSecondaryButtonStyle}"
                            Command="{Binding BrowseLocationCommand}"
                            Padding="12,8"
                            Margin="8,0,0,0"
                            FontSize="12"/>
                    <TextBox Style="{StaticResource FormTextBoxStyle}"
                             Text="{Binding ProjectLocation, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="True"
                             ToolTip="{Binding ProjectLocation}"/>
                </DockPanel>
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,0,0,20">
                <Button Content="Cancel"
                        Style="{StaticResource ModalSecondaryButtonStyle}"
                        Command="{Binding CancelCommand}"
                        Padding="16,8"
                        Margin="0,0,10,0"/>
                <Button Content="OK"
                        Style="{StaticResource ModalPrimaryButtonStyle}"
                        Command="{Binding CreateProjectCommand}"
                        Padding="24,8"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
