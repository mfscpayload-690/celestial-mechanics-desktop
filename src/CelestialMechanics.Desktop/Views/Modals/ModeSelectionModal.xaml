<UserControl x:Class="CelestialMechanics.Desktop.Views.Modals.ModeSelectionModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Mode Selection: Simulation or Observation -->
    <Border HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="400" Height="350"
            Background="{StaticResource ModalPanel}"
            CornerRadius="16"
            BorderBrush="{StaticResource BorderPrimary}"
            BorderThickness="1"
            Padding="40,36">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                <TextBlock Text="CELESTIAL MECHANICS"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5"/>
                <TextBlock Text="Desktop Simulator"
                           FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Mode Buttons -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <Button Content="Simulation"
                        Style="{StaticResource ModalPrimaryButtonStyle}"
                        Command="{Binding SelectSimulationCommand}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,12"/>

                <Button Content="Observation"
                        Style="{StaticResource ModalSecondaryButtonStyle}"
                        IsEnabled="False"
                        Opacity="0.4"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,4"/>
                <TextBlock Text="Coming in a future update"
                           FontSize="10" FontStyle="Italic"
                           Foreground="{StaticResource TextDisabledBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Exit -->
            <Button Grid.Row="2"
                    Content="Exit"
                    Style="{StaticResource ModalExitButtonStyle}"
                    Command="{Binding ExitCommand}"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0"/>
        </Grid>
    </Border>
</UserControl>
