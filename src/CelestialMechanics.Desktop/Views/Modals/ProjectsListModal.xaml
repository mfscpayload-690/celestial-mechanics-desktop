<UserControl x:Class="CelestialMechanics.Desktop.Views.Modals.ProjectsListModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Projects List: Browse and open saved projects -->
    <Border HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="400" Height="350"
            Background="{StaticResource ModalPanel}"
            CornerRadius="16"
            BorderBrush="{StaticResource BorderPrimary}"
            BorderThickness="1"
            Padding="20,0">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0"
                       Text="PROJECTS"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource CyanAccent}"
                       HorizontalAlignment="Center"
                       Margin="0,22,0,15"/>

            <!-- Project List -->
            <Grid Grid.Row="1">
                <!-- Empty State -->
                <TextBlock Text="No projects yet"
                           FontSize="13"
                           Foreground="{StaticResource TextDisabledBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Projects.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- List -->
                <ListBox ItemsSource="{Binding Projects}"
                         SelectedItem="{Binding SelectedProject}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Padding="12,10"
                                                BorderBrush="Transparent"
                                                BorderThickness="3,0,0,0">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{StaticResource SurfaceHover}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{StaticResource Surface}"/>
                                                <Setter TargetName="Bd" Property="BorderBrush"
                                                        Value="{StaticResource CyanAccent}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <StackPanel.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Open"
                                                  Command="{Binding DataContext.OpenProjectItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                  CommandParameter="{Binding}"/>
                                        <MenuItem Header="Delete"
                                                  Command="{Binding DataContext.DeleteProjectItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                  CommandParameter="{Binding}"/>
                                    </ContextMenu>
                                </StackPanel.ContextMenu>
                                <TextBlock Text="{Binding Name}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <DockPanel Margin="0,3,0,0">
                                    <TextBlock Text="{Binding LastModifiedDate, StringFormat='{}{0:MMM dd, yyyy}'}"
                                               DockPanel.Dock="Right"
                                               FontSize="11"
                                               Foreground="{StaticResource TextDisabledBrush}"/>
                                    <TextBlock Text="{Binding Path}"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,18">
                <Button Content="Cancel"
                        Style="{StaticResource ModalSecondaryButtonStyle}"
                        Command="{Binding CancelCommand}"
                        Padding="16,8"
                        Margin="0,0,10,0"/>
                <Button Content="Open"
                        Style="{StaticResource ModalPrimaryButtonStyle}"
                        Command="{Binding OpenSelectedProjectCommand}"
                        Padding="20,8"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
