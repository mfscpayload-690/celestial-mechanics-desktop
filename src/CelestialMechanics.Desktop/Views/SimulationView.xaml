<UserControl x:Class="CelestialMechanics.Desktop.Views.SimulationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CelestialMechanics.Desktop.Views"
        xmlns:modals="clr-namespace:CelestialMechanics.Desktop.Views.Modals"
        xmlns:panels="clr-namespace:CelestialMechanics.Desktop.Views.Panels"
        xmlns:vm="clr-namespace:CelestialMechanics.Desktop.ViewModels"
        xmlns:conv="clr-namespace:CelestialMechanics.Desktop.Converters"
        Background="{StaticResource BackgroundPrimary}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedBodyCommand}"/>
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Row 0: Compact top toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: Main workspace -->
            <RowDefinition Height="*"/>
            <!-- Row 2: Compact bottom bar -->
            <RowDefinition Height="Auto"/>
            <!-- Row 3: Status bar -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 0 – COMPACT TOP TOOLBAR
             Title + sim readouts + view toggles + FPS
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource MenuBarBackground}"
                BorderBrush="{StaticResource BorderBaseBrush}" BorderThickness="0,0,0,1"
                Visibility="{Binding IsIdeActive, Converter={StaticResource BoolToVis}}">
            <DockPanel Height="32" Margin="10,0">
                <!-- Left: Title -->
                <TextBlock DockPanel.Dock="Left"
                           Text="☉ CELESTIAL MECHANICS"
                           Foreground="{StaticResource AccentCyanBrush}"
                           FontSize="12" FontWeight="Bold" FontFamily="Consolas"
                           VerticalAlignment="Center" Margin="0,0,20,0"/>

                <!-- Left: Sim data readouts -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="SIM TIME:" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="10" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding SimTimeText}" Foreground="{StaticResource TextDataBrush}"
                               FontSize="10" FontFamily="Consolas" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,16,0" MinWidth="80"/>

                    <TextBlock Text="STEP:" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="10" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding BodyCountText}" Foreground="{StaticResource TextDataBrush}"
                               FontSize="10" FontFamily="Consolas" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                </StackPanel>

                <!-- Right: FPS + view toggles -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- View toggles -->
                    <CheckBox Content="Grid" IsChecked="{Binding ShowGrid, Mode=TwoWay}"
                              Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"
                              VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <CheckBox Content="Trails" IsChecked="{Binding ShowTrails, Mode=TwoWay}"
                              Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"
                              VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <CheckBox Content="Stars" IsChecked="{Binding ShowStarfield, Mode=TwoWay}"
                              Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"
                              VerticalAlignment="Center" Margin="0,0,12,0"/>

                    <!-- Separator -->
                    <Rectangle Width="1" Height="16" Fill="{StaticResource BorderBaseBrush}" Margin="0,0,12,0"/>

                    <!-- Time scale -->
                    <TextBlock Text="{Binding TimeScale, StringFormat={}{0:F1}x}"
                               Foreground="{StaticResource AccentCyanBrush}"
                               FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,12,0" MinWidth="30"/>

                    <!-- FPS -->
                    <TextBlock Text="{Binding FpsText}"
                               Foreground="{StaticResource StatusGreenBrush}"
                               FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Center spacer -->
                <Border/>
            </DockPanel>
        </Border>

        <!-- Minimal menu bar (IDE mode) -->
        <Menu Grid.Row="0" Style="{StaticResource MenuBarStyle}"
              Visibility="{Binding IsIdeActive, Converter={StaticResource BoolToVis}}"
              VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,0,0,0"
              Panel.ZIndex="10" Opacity="0">
            <!-- Hidden but keyboard shortcuts still work via InputBindings -->
        </Menu>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 1 – MAIN WORKSPACE
             Left: Scene Outliner + Simulation Settings (stacked)
             Center: Viewport
             Right: Inspector / Physics tabs
             ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">

            <!-- Background video (behind modals) -->
            <MediaElement x:Name="BackgroundVideo"
                          Stretch="UniformToFill"
                          LoadedBehavior="Manual"
                          UnloadedBehavior="Manual"
                          IsHitTestVisible="False"
                          Opacity="0.4"
                          Visibility="{Binding IsModalVisible, Converter={StaticResource BoolToVis}}">
                <MediaElement.Effect>
                    <BlurEffect Radius="20"/>
                </MediaElement.Effect>
            </MediaElement>

            <!-- Fallback dark background -->
            <Border Background="{StaticResource BackgroundPrimary}"
                    IsHitTestVisible="False"
                    Visibility="{Binding IsModalVisible, Converter={StaticResource BoolToVis}}"/>

            <!-- ── IDE 3-Column Workspace ─────────────────── -->
            <Grid Visibility="{Binding IsIdeActive, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <!-- Col 0: Left panel (Scene Outliner + Settings stacked) -->
                    <ColumnDefinition Width="240" MinWidth="180" MaxWidth="400"/>
                    <!-- Col 1: GridSplitter -->
                    <ColumnDefinition Width="1"/>
                    <!-- Col 2: Center viewport area -->
                    <ColumnDefinition Width="*" MinWidth="400"/>
                    <!-- Col 3: GridSplitter -->
                    <ColumnDefinition Width="1"/>
                    <!-- Col 4: Right panel (Inspector + Settings tabs) -->
                    <ColumnDefinition Width="280" MinWidth="200" MaxWidth="500"/>
                </Grid.ColumnDefinitions>

                <!-- ── Left Panel: Scene Outliner (top) + Settings (bottom) ── -->
                <Grid Grid.Column="0"
                      Visibility="{Binding DataContext.ShowSceneOutliner,
                                   RelativeSource={RelativeSource AncestorType=UserControl},
                                   Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>     <!-- Scene outliner -->
                        <RowDefinition Height="1"/>     <!-- Splitter -->
                        <RowDefinition Height="Auto"/>  <!-- Analysis panel -->
                    </Grid.RowDefinitions>

                    <!-- Scene Outliner -->
                    <panels:SceneOutlinerPanel
                        Grid.Row="0"
                        DataContext="{Binding SceneOutlinerVm}"/>

                    <!-- Horizontal splitter -->
                    <GridSplitter Grid.Row="1" Height="1"
                                  Background="{StaticResource BorderBaseBrush}"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

                    <!-- Analysis/Energy Panel (collapsible) -->
                    <panels:AnalysisPanel
                        Grid.Row="2"
                        Height="180"
                        DataContext="{Binding}"
                        Visibility="{Binding DataContext.IsAnalyseMode,
                                     RelativeSource={RelativeSource AncestorType=UserControl},
                                     Converter={StaticResource BoolToVis}}"/>
                </Grid>

                <!-- Left GridSplitter -->
                <GridSplitter Grid.Column="1" Width="1"
                              Background="{StaticResource BorderBaseBrush}"
                              Visibility="{Binding ShowSceneOutliner,
                                           Converter={StaticResource BoolToVis}}"/>

                <!-- ── Center: Body Type Palette + Viewport ──────── -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Body Type Palette (visible only in Add mode) -->
                    <panels:BodyTypePalette
                        Grid.Row="0"
                        Visibility="{Binding DataContext.IsAddMode,
                                     RelativeSource={RelativeSource AncestorType=UserControl},
                                     Converter={StaticResource BoolToVis}}"/>

                    <!-- OpenGL Viewport -->
                    <views:ViewportPanel x:Name="Viewport" Grid.Row="1"/>
                </Grid>

                <!-- Right GridSplitter -->
                <GridSplitter Grid.Column="3" Width="1"
                              Background="{StaticResource BorderBaseBrush}"
                              Visibility="{Binding ShowInspector,
                                           Converter={StaticResource BoolToVis}}"/>

                <!-- ── Right Panel: TabControl (Inspector + Settings) ── -->
                <TabControl Grid.Column="4"
                            Style="{StaticResource SpaceTabControlStyle}"
                            SelectedIndex="{Binding RightPanelTabIndex, Mode=TwoWay}"
                            Visibility="{Binding DataContext.ShowInspector,
                                         RelativeSource={RelativeSource AncestorType=UserControl},
                                         Converter={StaticResource BoolToVis}}">
                    <TabItem Header="Inspector" Style="{StaticResource SpaceTabItemStyle}">
                        <panels:BodyInspectorPanel
                            DataContext="{Binding BodyInspectorVm}"/>
                    </TabItem>
                    <TabItem Header="Physics" Style="{StaticResource SpaceTabItemStyle}">
                        <panels:SimulationSettingsPanel
                            DataContext="{Binding SimulationSettingsVm}"/>
                    </TabItem>
                </TabControl>
            </Grid>

            <!-- ── Modal Navigation Overlay ─────────────────── -->
            <Grid Visibility="{Binding IsModalVisible, Converter={StaticResource BoolToVis}}"
                  Background="{StaticResource ModalOverlay}">

                <!-- Mode Selection -->
                <modals:ModeSelectionModal
                    DataContext="{Binding ModeSelectionVm}">
                    <modals:ModeSelectionModal.Style>
                        <Style TargetType="modals:ModeSelectionModal">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.NavState, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             Value="{x:Static vm:NavigationState.ModeSelection}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </modals:ModeSelectionModal.Style>
                </modals:ModeSelectionModal>

                <!-- Simulation Menu -->
                <modals:SimulationMenuModal
                    DataContext="{Binding SimulationMenuVm}">
                    <modals:SimulationMenuModal.Style>
                        <Style TargetType="modals:SimulationMenuModal">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.NavState, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             Value="{x:Static vm:NavigationState.SimulationMenu}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </modals:SimulationMenuModal.Style>
                </modals:SimulationMenuModal>

                <!-- New Project -->
                <modals:NewProjectModal
                    DataContext="{Binding NewProjectVm}">
                    <modals:NewProjectModal.Style>
                        <Style TargetType="modals:NewProjectModal">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.NavState, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             Value="{x:Static vm:NavigationState.NewProject}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </modals:NewProjectModal.Style>
                </modals:NewProjectModal>

                <!-- Projects List -->
                <modals:ProjectsListModal
                    DataContext="{Binding ProjectsListVm}">
                    <modals:ProjectsListModal.Style>
                        <Style TargetType="modals:ProjectsListModal">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.NavState, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             Value="{x:Static vm:NavigationState.ProjectsList}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </modals:ProjectsListModal.Style>
                </modals:ProjectsListModal>

                <!-- File Menu -->
                <modals:FileMenuModal
                    DataContext="{Binding FileMenuVm}">
                    <modals:FileMenuModal.Style>
                        <Style TargetType="modals:FileMenuModal">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.NavState, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             Value="{x:Static vm:NavigationState.FileMenu}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </modals:FileMenuModal.Style>
                </modals:FileMenuModal>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 2 – COMPACT BOTTOM BAR
             Play / Pause / Reset + sim state + time scale slider
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource MenuBarBackground}"
                BorderBrush="{StaticResource BorderBaseBrush}"
                BorderThickness="0,1,0,0"
                Height="36"
                Visibility="{Binding IsControlBarVisible, Converter={StaticResource BoolToVis}}">
            <DockPanel Margin="10,0">

                <!-- Left: Playback controls -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="▶ Play" Command="{Binding StartSimulationCommand}"
                            Style="{StaticResource CompactToolButton}" Margin="0,0,4,0"/>
                    <Button Content="⏸ Pause" Command="{Binding PauseSimulationCommand}"
                            Style="{StaticResource CompactToolButton}" Margin="0,0,4,0"/>
                    <Button Content="⏮ Reset" Command="{Binding ResetSimulationCommand}"
                            Style="{StaticResource CompactToolButton}" Margin="0,0,12,0"/>

                    <!-- Separator -->
                    <Rectangle Width="1" Height="18" Fill="{StaticResource BorderBaseBrush}" Margin="0,0,12,0"/>

                    <!-- Mode buttons (compact) -->
                    <Button Content="+ Add Body" Command="{Binding EnterAddModeCommand}"
                            Margin="0,0,4,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource CompactToolButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAddMode}" Value="True">
                                        <Setter Property="Background" Value="#1A00D4FF"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentCyanBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Simulate" Command="{Binding EnterSimulateModeCommand}"
                            Margin="0,0,4,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource CompactToolButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSimulateMode}" Value="True">
                                        <Setter Property="Background" Value="#1A00D4FF"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentCyanBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Edit" Command="{Binding EnterEditModeCommand}"
                            Margin="0,0,4,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource CompactToolButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                        <Setter Property="Background" Value="#1A00D4FF"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentCyanBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Analysis" Command="{Binding EnterAnalyseModeCommand}"
                            Margin="0,0,4,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource CompactToolButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAnalyseMode}" Value="True">
                                        <Setter Property="Background" Value="#1A00D4FF"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentCyanBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="⚙" Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource CompactToolButton}" ToolTip="Physics settings"/>
                </StackPanel>

                <!-- Right: Sim state + time scale -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Time scale slider -->
                    <TextBlock Text="Speed:" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="10" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Slider Style="{StaticResource CyanSliderStyle}" Width="120"
                            Value="{Binding TimeScale, Mode=TwoWay}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TimeScale, StringFormat={}{0:F1}x}"
                               Foreground="{StaticResource AccentCyanBrush}"
                               FontFamily="Consolas" FontSize="10" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="6,0,12,0" MinWidth="30"/>

                    <!-- Sim state indicator -->
                    <TextBlock Text="{Binding SimulationStateText}"
                               Foreground="{StaticResource AccentCyanBrush}"
                               FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Center spacer -->
                <Border/>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 3 – STATUS BAR
             ═══════════════════════════════════════════════════════════ -->
        <StatusBar Grid.Row="3" Style="{StaticResource CompactStatusBarStyle}"
                   Visibility="{Binding IsStatusBarVisible, Converter={StaticResource BoolToVis}}">
            <StatusBarItem>
                <TextBlock Text="{Binding FpsText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding BodyCountText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding PhysicsTimeText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding RenderTimeText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding SimTimeText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding TotalEnergyText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding MomentumText}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding SimulationStateText}"
                           Foreground="{StaticResource AccentCyanBrush}"
                           FontWeight="SemiBold"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
